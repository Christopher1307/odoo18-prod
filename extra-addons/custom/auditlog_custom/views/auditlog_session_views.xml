<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_auditlog_http_session_tree_inherit" model="ir.ui.view">
        <field name="name">auditlog.http.session.tree.inherit</field>
        <field name="model">auditlog.http.session</field>
        <field name="inherit_id" ref="auditlog.view_auditlog_http_session_tree"/>
        <field name="arch" type="xml">
            
            <xpath expr="//field[@name='create_date']" position="attributes">
                <attribute name="column_invisible">True</attribute>
            </xpath>

            <xpath expr="//field[@name='user_id']" position="after">
                <field name="x_fecha_accion"/>
                <field name="x_accion_usuario"/>
            </xpath>

        </field>
    </record>
</odoo>